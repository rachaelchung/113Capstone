# Copy to .env and fill in. Never commit .env.
#
# Start with Flask, then point the tracker meta tag at this service URL:
#   flask --app wsgi:app run --port 8000
# Production:
#   gunicorn -w 2 -b 0.0.0.0:8000 wsgi:app

OPENAI_API_KEY=
# Cheap default; override with gpt-4o etc. if you want
OPENAI_MODEL=gpt-4o-mini

# Comma-separated browser origins allowed to call this API (CORS)
CORS_ORIGINS=http://127.0.0.1:8080,http://localhost:8080,http://127.0.0.1:5500,http://localhost:5500

# Auth: Flask session + JWT signing (use a long random string in production)
SECRET_KEY=change-me-to-a-long-random-secret

# Where users land after Google OAuth (must match a CORS origin). No trailing slash.
FRONTEND_ORIGIN=http://127.0.0.1:5500

# Google OAuth (Web application client). Authorized redirect URI on the client must be:
#   {API public URL}/api/auth/google/callback
# e.g. http://127.0.0.1:8001/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional. Default: SQLite file at backend/instance/tracker.db (created on first run).
# DATABASE_URL=postgresql+psycopg://user:pass@host/dbname
